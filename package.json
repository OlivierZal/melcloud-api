{
  "name": "@olivierzal/melcloud-api",
  "version": "38.0.1",
  "description": "MELCloud API for Node.js",
  "keywords": [
    "melcloud",
    "api"
  ],
  "homepage": "https://olivierzal.github.io/melcloud-api/",
  "bugs": {
    "url": "https://github.com/OlivierZal/melcloud-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/melcloud-api.git"
  },
  "license": "MIT",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./classic": {
      "types": "./dist/classic.d.ts",
      "default": "./dist/classic.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./home": {
      "types": "./dist/home.d.ts",
      "default": "./dist/home.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "docs": "typedoc",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run format && npm run docs",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test -- --update",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "tough-cookie": "^6.0.1",
    "undici": "^8.2.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.33",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260429.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-coverage": "^4.0.3",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
