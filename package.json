{
  "name": "@olivierzal/melcloud-api",
  "version": "33.0.0",
  "description": "MELCloud API for Node.js",
  "keywords": [
    "melcloud",
    "api"
  ],
  "homepage": "https://olivierzal.github.io/melcloud-api/",
  "bugs": {
    "url": "https://github.com/OlivierZal/melcloud-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/melcloud-api.git"
  },
  "license": "MIT",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./classic": {
      "types": "./dist/classic.d.ts",
      "default": "./dist/classic.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "default": "./dist/decorators/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "default": "./dist/entities/index.js"
    },
    "./enum-mappings": {
      "types": "./dist/enum-mappings.d.ts",
      "default": "./dist/enum-mappings.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./facades": {
      "types": "./dist/facades/index.d.ts",
      "default": "./dist/facades/index.js"
    },
    "./home": {
      "types": "./dist/home.d.ts",
      "default": "./dist/home.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./resilience": {
      "types": "./dist/resilience/index.d.ts",
      "default": "./dist/resilience/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "docs": "typedoc",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run format",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test -- --update",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "tough-cookie": "^6.0.1",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
