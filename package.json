{
  "name": "@olivierzal/melcloud-api",
  "version": "23.0.0-rc.0",
  "description": "MELCloud API for Node.js",
  "keywords": [
    "melcloud",
    "api"
  ],
  "homepage": "https://olivierzal.github.io/melcloud-api/",
  "bugs": {
    "url": "https://github.com/OlivierZal/melcloud-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/melcloud-api.git"
  },
  "license": "ISC",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/main.js",
    "./constants": "./dist/constants.js"
  },
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "docs": "typedoc",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run format",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "luxon": "^3.7.2",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.21",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-package-json": "^0.91.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
