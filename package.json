{
  "name": "@olivierzal/melcloud-api",
  "version": "21.0.0",
  "description": "MELCloud API for Node.js",
  "keywords": [
    "melcloud",
    "api"
  ],
  "homepage": "https://olivierzal.github.io/melcloud-api/",
  "bugs": {
    "url": "https://github.com/OlivierZal/melcloud-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/melcloud-api.git"
  },
  "license": "ISC",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/main.js"
  },
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "docs": "typedoc && npm run format:docs",
    "format": "prettier . --check",
    "format:docs": "prettier docs --ignore-path --write",
    "format:fix": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.18",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260315.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-package-json": "^0.91.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  }
}
