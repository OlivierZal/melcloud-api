{
  "name": "@olivierzal/melcloud-api",
  "version": "41.0.0",
  "description": "MELCloud API for Node.js",
  "keywords": [
    "melcloud",
    "api"
  ],
  "homepage": "https://olivierzal.github.io/melcloud-api/",
  "bugs": {
    "url": "https://github.com/OlivierZal/melcloud-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/melcloud-api.git"
  },
  "license": "MIT",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./classic": {
      "types": "./dist/classic.d.ts",
      "default": "./dist/classic.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./home": {
      "types": "./dist/home.d.ts",
      "default": "./dist/home.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node ./node_modules/@typescript/native/bin/tsc --project tsconfig.build.json",
    "docs": "typedoc",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "npm run lint -- --fix",
    "lint:package": "npm run build && publint --strict",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run format && npm run docs",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test -- --update",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit"
  },
  "dependencies": {
    "temporal-polyfill": "^1.0.1",
    "tough-cookie": "^6.0.1",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.1.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-unicorn": "^70.0.0",
    "eslint-plugin-yml": "^3.5.0",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "publint": "^0.3.21",
    "typedoc": "^0.28.20",
    "typedoc-plugin-coverage": "^4.0.3",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
